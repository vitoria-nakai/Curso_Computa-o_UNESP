/*========== PILHA DE LISTA ENCADEADA ESTÁTICA ==========*/

#include<stdio.h>
#include<stdlib.h>
#define MAX 10

typedef struct{
    int item;
    int prox;
} No;

typedef struct{
    No nos[MAX];
    int inicio;
    int disponivel;
} LEE;

void setList(LEE * list){
    //conectar os nós pelos índices
    for(int i = 0; i < MAX - 1; i++){
        list->nos[i].prox = i + 1;
    }
    list->nos[MAX - 1].prox = -1;
    list->inicio = -1;
    list->disponivel = 0;
}

void print(LEE * list){
    printf("\n---------- ELEMENTOS ----------\n");
    if(list->inicio == -1){
        printf("(lista vazia)");
    }else{
        for(int i = list->inicio; i != -1; i = list->nos[i].prox){
            printf("%d\t", list->nos[i].item);
        }
        printf("\n");
    }
}

int getNode(LEE * list){
    if(list->disponivel == -1){
        return -1;
    } else { 
        int index = list->disponivel;
        list->disponivel = list->nos[index].prox;
        return index;
    }
}

void add(LEE * list, int value){
    int index = getNode(list);
    if(index == -1){
        printf("A lista já está cheia. Tente novamente.");
    }else{
        list->nos[index].item = value;
        list->nos[index].prox = list->inicio;
        list->inicio = index;
    }
}

void delete(LEE * list){
    if(list->inicio == -1){
        printf("A lista já está vazia. Tente novamente.");
    }else{
        int i = list->inicio;
        list->inicio = list->nos[i].prox;
        list->nos[i].prox = list->disponivel;
        list->disponivel = i;
    }
}

int main(){
    LEE minhaLista;
    setList(&minhaLista);
    int valor, acao;
    while(1){
        printf("\n\n========== PILHA DE LISTA ENCADEADA ESTÁTICA ==========\n\n");
        print(&minhaLista);
        printf("\n---------- OPERAÇÕES ----------\n"
            "0 - Desligar o sistema;\n"
            "1 - Adicionar elementos;\n"
            "2 - Retirar elementos;\n\n"
            "Ação: ");
        scanf("%d", &acao);
        if(acao == 0){
            printf("Desligando o sistema... . Obrigada pela atenção.");
            break;
        }else if(acao == 1){
            printf("Digite o valor que deseja adicionar: ");
            scanf("%d", &valor);
            add(&minhaLista, valor);
        }else if(acao == 2){
            delete(&minhaLista);
        }else{
            printf("Ação não reconhecida. Tente novamente.");
        }
        
    }
    return 0;
}

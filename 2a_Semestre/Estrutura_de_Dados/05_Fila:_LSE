/*========== FILA SEQUENCIAL ESTÁTICA ==========*/
#include<stdio.h>
#include<stdlib.h>
#define MAX 10 

typedef struct{
    int itens[MAX];
    int quantidade;
} FSE;

void print(FSE list){
    printf("\n---------- ELEMENTOS ----------\n");
    if(list.quantidade == 0){
        printf("\n(lista vazia)\n");
    }else{
        for(int i = 0; i < list.quantidade; i++){
            printf("%d\t", list.itens[i]);
        }
        printf("\n");
    }    
}

void add(FSE * list, int value){
    if(list->quantidade == MAX - 1){
        printf("A lista já está cheia. Tente novamente.");
    }else{
        list->itens[list->quantidade] = value;
        list->quantidade++;
    }
}

void pop(FSE * list){
    for(int i = 0; i < list->quantidade; i++){
        list->itens[i] = list->itens[i + 1];
    }
    list->quantidade--;
}

int main(){
    FSE minhaLista;
    minhaLista.quantidade = 0;
    
    while(1){
        int acao, valor;
        printf("\n\n========== FILA SEQUENCIAL ESTATICA ==========\n\n");
        print(minhaLista);
        printf("\n ---------- OPERAÇÕES -----------\n\n"
            "0 - Desligar o sistema.\n"
            "1 - Adicionar elementos;\n"
            "2 - Remover elementos;\n\n"
            "Ação: ");
        scanf("%d", &acao);
        if(acao == 0){
            printf("Desligando o sistema... . Obrigada pela atenção.");
            break;
        }else if(acao == 1){
            printf("Digite o elemento que deseja adicionar: ");
            scanf("%d", &valor);
            add(&minhaLista, valor);
        }else if(acao == 2){
            pop(&minhaLista);
        }else{
            printf("Ação não reconhecida. Tente novamente.");
        }
    }
    return 0;
}

 - Apagar uma lista
 - Inserir elemento numa certa posição da lista
*/

#include<stdio.h>
#include<stdlib.h>

#define MAX 10 // MAX = 10


// DEFINIR A ESTRUTURA DA LISTA SEQUENCIAL ESTÁTICA
typedef struct{
    int itens[MAX]; //O array com os elementos
    int quantidade; // quantidade máxima de elementos
} LSE;

void printList(LSE list){
    printf("\n ---------- LISTA ----------\n");
    if(list.quantidade == 0){
        printf("(sem elementos)\n");
    }
    else{
        for(int i = 0; i < list.quantidade; i++){
        printf("%d\t", list.itens[i]);
        }
        printf("\n");
    }
}

int searchPosition(LSE list, int value){
    int i = 0;
    for(i; i < list.quantidade; i++){
        if(list.itens[i] == value) break;
    }
    return i;
}

void insertPosition(LSE * list, int value, int position){
    if(list->quantidade == 0){
        list->itens[0] = value;
        list->quantidade++;
    }else if(list->quantidade == MAX){
        printf("A lista está cheia. Retire algumas antes de tentar de novo.\n");
    }else if(position > list->quantidade){
        printf("Há apenas %d elementos. Sua posição não se encaixa entre os elementos. Tente novamente.", list->quantidade);
    }else if(position < 0){
        printf("Não aceitamos posições com número negativo. Tente novamente.");
    }else{
        int i = list->quantidade - 1;
        for(i; i >= position; i--){
            list->itens[i + 1] = list->itens[i];
            }   
        list->itens[i + 1] = value;
        list->quantidade++;
    }
}

